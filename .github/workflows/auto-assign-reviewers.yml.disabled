name: Auto-assign Reviewers

on:
  pull_request:
    types: [opened, ready_for_review]

jobs:
  assign:
    runs-on: ubuntu-latest
    steps:
      - name: Assigne la squad opposée selon le numéro de lot
        uses: actions/github-script@v7
        with:
          script: |
            const branch = context.payload.pull_request.head.ref;
            const lotMatch = branch.match(/feature\/lot-(\d+)/);
            if (!lotMatch) {
              core.info("Pas un branche feature/lot-N — pas de routage automatique.");
              return;
            }
            const lotNum = parseInt(lotMatch[1], 10);
            // Lots impairs → squad-cursor (Théo/Léna/Alma)
            // Lots pairs → squad-claude (Léo/Ada/Iris)
            const team = lotNum % 2 === 0 ? 'squad-claude' : 'squad-cursor';
            core.info(`Lot ${lotNum} → assignation à @org/${team}`);
            try {
              await github.rest.pulls.requestReviewers({
                owner: context.repo.owner,
                repo: context.repo.repo,
                pull_number: context.payload.pull_request.number,
                team_reviewers: [team],
              });
            } catch (err) {
              core.warning(
                `Impossible d'assigner ${team}: ${err.message}. Vérifie que le team existe dans l'organisation.`
              );
            }
